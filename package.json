{
  "name": "twitch-drop-farmer",
  "version": "1.0.0",
  "description": "Auto Farm Twitch Drops Dashboard",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.twitch.drops.farmer.pro",
    "productName": "Twitch Drops Farmer PRO",
    "artifactName": "TwitchDropsFarmerPRO-${version}-Setup.${ext}",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "files": [
      "**/*",
      "!node_modules/*",
      "node_modules/ws/**/*"
    ],
    "asar": true
  },
  "author": "Lokalizator",
  "license": "ISC",
  "dependencies": {
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8"
  }
}
